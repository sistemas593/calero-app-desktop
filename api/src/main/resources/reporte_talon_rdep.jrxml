    <!-- ================= TITLE ================= -->
    <title>
        <band height="60">
            <frame>
                <reportElement x="0" y="0" width="535" height="50" backcolor="#0066CC" mode="Opaque"/>
                <staticText>
                    <reportElement x="0" y="5" width="535" height="55" forecolor="#FFFFFF"/>
                    <textElement textAlignment="Center">
                        <font size="14" isBold="true"/>
                    </textElement>
                    <text><![CDATA[TALON RESUMEN DE RETENCIONES EN LA FUENTE DE IMPUESTO
                     A LA RENTA BAJO RELACION DE DEPENDENCIA SERVICIO DE RENTAS INTERNAS]]></text>
                </staticText>
            </frame>
        </band>
    </title>

