<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="estado_situacion_financiera"
              pageWidth="595" pageHeight="842"
              columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="12345678-aaaa-bbbb-cccc-999999999999">

    <!-- ====================== ESTILOS ====================== -->
    <style name="estiloNormal" fontSize="9"/>
    <style name="estiloTotal" fontSize="9" isBold="true"/>
    <style name="estiloTitulo" fontSize="13" isBold="true"/>

    <!-- ====================== PARAMETROS ====================== -->
    <parameter name="empresa" class="java.lang.String"/>
    <parameter name="sucursal" class="java.lang.String"/>
    <parameter name="fechaDesde" class="java.lang.String"/>
    <parameter name="fechaHasta" class="java.lang.String"/>
    <parameter name="fechaActual" class="java.lang.String"/>
    <parameter name="gerente" class="java.lang.String"/>
    <parameter name="contador" class="java.lang.String"/>
    <parameter name="idenGerente" class="java.lang.String"/>
    <parameter name="idenContador" class="java.lang.String"/>

    <!-- ====================== CAMPOS ====================== -->
    <field name="codigoCuenta" class="java.lang.String"/>
    <field name="cuenta" class="java.lang.String"/>
    <field name="saldoFinal" class="java.lang.String"/>
    <field name="totalMayor" class="java.lang.Boolean"/>


    <group name="lineasDespuesDetalle">
        <groupFooter>
            <band height="8">

                <line>
                    <reportElement x="0" y="0" width="555" height="1"/>
                </line>

                <line>
                    <reportElement x="0" y="3" width="555" height="1"/>
                </line>

            </band>
        </groupFooter>
    </group>


    <!-- ====================== TITLE ====================== -->
    <title>
        <band height="80">

            <textField>
                <reportElement x="0" y="0" width="555" height="20"/>
                <textElement>
                    <font size="15" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{empresa}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="22" width="555" height="18"/>
                <textElement>
                    <font size="13" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Estado de Resultados"]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="45" width="555" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[
                    "Sucursal: " + $P{sucursal}
                    + " | Desde: " + $P{fechaDesde}
                    + " Hasta: " + $P{fechaHasta}
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="405" y="0" width="150" height="15"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{fechaActual}]]></textFieldExpression>
            </textField>

        </band>
    </title>

    <!-- ====================== COLUMN HEADER ====================== -->
    <columnHeader>
        <band height="28">

            <staticText>
                <reportElement x="0" y="0" width="80" height="20"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Código]]></text>
            </staticText>

            <staticText>
                <reportElement x="80" y="0" width="355" height="20"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Cuenta]]></text>
            </staticText>

            <staticText>
                <reportElement x="435" y="0" width="120" height="20"/>
                <textElement textAlignment="Right">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Saldo]]></text>
            </staticText>

            <line>
                <reportElement x="0" y="22" width="555" height="1"/>
            </line>

            <line>
                <reportElement x="0" y="25" width="555" height="1"/>
            </line>

        </band>
    </columnHeader>

    <!-- ====================== DETAIL ====================== -->
    <detail>
        <band height="30">

            <!-- ====================== PRIMERA LINEA DE LOS TOTALES. ====================== -->

            <frame>
                <reportElement x="0" y="0" width="555" height="2">
                    <printWhenExpression><![CDATA[Boolean.TRUE.equals($F{totalMayor})]]></printWhenExpression>
                </reportElement>
                <line>
                    <reportElement x="0" y="0" width="555" height="1"/>
                </line>
            </frame>


            <!-- Código -->
            <textField>
                <reportElement x="0" y="0" width="80" height="20"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{codigoCuenta}]]></textFieldExpression>
            </textField>

            <!-- Cuenta -->
            <textField isStretchWithOverflow="true">
                <reportElement x="80" y="0" width="355" height="20"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{cuenta}]]></textFieldExpression>
            </textField>

            <frame>
                <reportElement x="435" y="0" width="120" height="5">
                    <printWhenExpression>
                        <![CDATA[$F{cuenta} != null && $F{cuenta}.startsWith("Total")]]></printWhenExpression>
                </reportElement>

                <line>
                    <reportElement x="0" y="0" width="120" height="1"/>
                </line>
            </frame>

            <frame>
                <reportElement x="0" y="0" width="555" height="2">
                    <printWhenExpression>
                        <![CDATA[$F{cuenta} != null && $F{cuenta}.startsWith("Resultado")]]></printWhenExpression>
                </reportElement>

                <line>
                    <reportElement x="0" y="0" width="555" height="1"/>
                </line>
            </frame>

            <!-- Saldo -->
            <textField pattern="#,##0.00">
                <reportElement x="435" y="0" width="120" height="20"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{saldoFinal}]]></textFieldExpression>
            </textField>

            <frame>
                <reportElement x="0" y="27" width="555" height="2">
                    <printWhenExpression><![CDATA[Boolean.TRUE.equals($F{totalMayor})]]></printWhenExpression>
                </reportElement>

                <line>
                    <reportElement x="0" y="0" width="555" height="1"/>
                </line>
            </frame>


        </band>
    </detail>

    <!-- ====================== SUMMARY / FIRMAS ====================== -->
    <summary>
        <band height="250">

            <staticText>
                <reportElement x="70" y="170" width="200" height="20"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[_________________________]]></text>
            </staticText>

            <staticText>
                <reportElement x="70" y="195" width="200" height="20"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[Gerente]]></text>
            </staticText>

            <textField>
                <reportElement x="70" y="210" width="200" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$P{gerente}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="70" y="225" width="200" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$P{idenGerente}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="320" y="170" width="200" height="20"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[_________________________]]></text>
            </staticText>

            <staticText>
                <reportElement x="320" y="195" width="200" height="20"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[Contador]]></text>
            </staticText>

            <textField>
                <reportElement x="320" y="210" width="200" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$P{contador}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="320" y="225" width="200" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$P{idenContador}]]></textFieldExpression>
            </textField>

        </band>
    </summary>

</jasperReport>
