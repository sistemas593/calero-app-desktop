<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="balance_comprobacion"
              pageWidth="595" pageHeight="842"
              columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="12345678-aaaa-bbbb-cccc-999999999999">

    <!-- ====================== ESTILOS ====================== -->
    <style name="estiloDetalle" fontSize="9"/>
    <style name="estiloTitulo" fontSize="12" isBold="true"/>
    <style name="estiloTotal" fontSize="9" isBold="true"/>

    <!-- ====================== PARAMETROS ====================== -->
    <parameter name="empresa" class="java.lang.String"/>
    <parameter name="sucursal" class="java.lang.String"/>
    <parameter name="fechaDesde" class="java.lang.String"/>
    <parameter name="fechaHasta" class="java.lang.String"/>
    <parameter name="fechaActual" class="java.lang.String"/>
    <parameter name="cuentaDesde" class="java.lang.String"/>
    <parameter name="totalDebe" class="java.lang.String"/>
    <parameter name="totalHaber" class="java.lang.String"/>

    <!-- ====================== CAMPOS ====================== -->
    <field name="fechaAsiento" class="java.lang.String"/>
    <field name="tipoAsiento" class="java.lang.String"/>
    <field name="numeroAsiento" class="java.lang.String"/>
    <field name="debe" class="java.lang.String"/>
    <field name="haber" class="java.lang.String"/>
    <field name="saldo" class="java.lang.String"/>
    <field name="concepto" class="java.lang.String"/>
    <field name="cuenta" class="java.lang.String"/>

    <!-- ====================== TITLE ====================== -->
    <title>
        <band height="80" splitType="Stretch">

            <textField>
                <reportElement x="0" y="0" width="500" height="20"/>
                <textElement>
                    <font isBold="true" size="15"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{empresa}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="20" width="500" height="20"/>
                <textElement>
                    <font size="13"/>
                </textElement>
                <textFieldExpression><![CDATA["Mayor General"]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="40" width="500" height="20"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[
                    "Sucursal: " + $P{sucursal}
                    + " / Desde: " + $P{fechaDesde}
                    + " Hasta: " + $P{fechaHasta}
                    + (
                        ($P{cuentaDesde} != null || $P{cuentaDesde} != null)
                        ? (
                            " / Cuenta "
                            + ($P{cuentaDesde} != null ? "Desde: " + $P{cuentaDesde} + " " : "")
                            + ($P{cuentaDesde} != null ? "Hasta: " + $P{cuentaDesde} : "")
                          )
                        : ""
                      )
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="390" y="15" width="150" height="20"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{fechaActual}]]></textFieldExpression>
            </textField>

        </band>
    </title>

    <!-- ====================== ENCABEZADOS ====================== -->
    <columnHeader>
        <band height="28">

            <line>
                <reportElement x="0" y="0" width="555" height="1"/>
            </line>

            <line>
                <reportElement x="0" y="3" width="555" height="1"/>
            </line>

            <!-- CUENTA -->
            <staticText>
                <reportElement x="0" y="6" width="80" height="20"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Cuenta]]></text>
            </staticText>

            <!-- FECHA -->
            <staticText>
                <reportElement x="80" y="6" width="60" height="20"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Fecha]]></text>
            </staticText>

            <!-- TIPO ASIENTO -->
            <staticText>
                <reportElement x="140" y="6" width="140" height="20"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Tp.Asiento]]></text>
            </staticText>

            <!-- TD NUMERO -->
            <staticText>
                <reportElement x="280" y="6" width="60" height="20"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[TD Número]]></text>
            </staticText>

            <!-- DETALLE -->
            <staticText>
                <reportElement x="340" y="6" width="80" height="20"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Detalle]]></text>
            </staticText>

            <!-- DEBE -->
            <staticText>
                <reportElement x="420" y="6" width="45" height="20"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Debe]]></text>
            </staticText>

            <!-- HABER -->
            <staticText>
                <reportElement x="465" y="6" width="45" height="20"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Haber]]></text>
            </staticText>

            <!-- SALDO -->
            <staticText>
                <reportElement x="510" y="6" width="45" height="20"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Saldo]]></text>
            </staticText>

        </band>
    </columnHeader>

    <!-- ====================== DETALLE ====================== -->
    <detail>
        <band height="20">

            <!-- CUENTA -->
            <textField>
                <reportElement x="0" y="0" width="80" height="20"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{cuenta}]]></textFieldExpression>
            </textField>

            <!-- FECHA -->
            <textField>
                <reportElement x="80" y="0" width="60" height="20"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{fechaAsiento}]]></textFieldExpression>
            </textField>

            <!-- TIPO ASIENTO -->
            <textField isStretchWithOverflow="true">
                <reportElement x="140" y="0" width="140" height="20"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{tipoAsiento}]]></textFieldExpression>
            </textField>

            <!-- NUMERO -->
            <textField>
                <reportElement x="280" y="0" width="60" height="20"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{numeroAsiento}]]></textFieldExpression>
            </textField>

            <!-- DETALLE -->
            <textField>
                <reportElement x="340" y="0" width="80" height="20"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{concepto}]]></textFieldExpression>
            </textField>

            <!-- DEBE -->
            <textField>
                <reportElement x="420" y="0" width="45" height="20"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{debe}]]></textFieldExpression>
            </textField>

            <!-- HABER -->
            <textField>
                <reportElement x="465" y="0" width="45" height="20"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{haber}]]></textFieldExpression>
            </textField>

            <!-- SALDO -->
            <textField>
                <reportElement x="510" y="0" width="45" height="20"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{saldo}]]></textFieldExpression>
            </textField>

        </band>
    </detail>

    <!-- ====================== TOTALES FINALES ====================== -->
    <summary>
        <band height="40">

            <!-- Línea solo desde Totales hacia los valores -->
            <line>
                <reportElement x="250" y="0" width="315" height="1"/>
            </line>

            <!-- TEXTO TOTALES -->
            <staticText>
                <reportElement x="250" y="0" width="90" height="15"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Totales:]]></text>
            </staticText>

            <!-- TOTAL DEBE -->
            <textField pattern="#,##0.00">
                <reportElement x="420" y="0" width="70" height="15"/>
                <textElement textAlignment="Center">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{totalDebe}]]></textFieldExpression>
            </textField>

            <!-- TOTAL HABER -->
            <textField pattern="#,##0.00">
                <reportElement x="465" y="0" width="70" height="15"/>
                <textElement textAlignment="Center">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{totalHaber}]]></textFieldExpression>
            </textField>

            <!-- PRIMERA LÍNEA (DEBAJO DE TOTALES) -->
            <line>
                <reportElement x="0" y="18" width="555" height="1"/>
            </line>

            <!-- SEGUNDA LÍNEA -->
            <line>
                <reportElement x="0" y="22" width="555" height="1"/>
            </line>

        </band>
    </summary>

</jasperReport>
